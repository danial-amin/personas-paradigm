# Copy this file to `.env` in the repo root and fill in values.
# `.env` is gitignored — do not commit secrets.
#
# Load order: this file is read automatically when you run
#   python scripts/run_persona_experiment.py
# if `python-dotenv` is installed (see requirements.txt).

# --- LLM API keys (set the ones that match models in your YAML config) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# --- Optional: which experiment YAML to use (default: experiment_config.yaml) ---
# EXPERIMENT_CONFIG=experiment_config.test.yaml
